# TikTok Backend Configuration
# Copy this to .env and fill in your ms_token
MS_TOKEN=your_ms_token_here

# Session config
TIKTOK_SESSIONS=2
TIKTOK_HEADLESS=true

# Live check interval (seconds)
LIVE_CHECK_INTERVAL=60

# SoCandyShop TikTok handle
TIKTOK_SHOP_HANDLE=soetsopains

# Server
HOST=0.0.0.0
PORT=3100
